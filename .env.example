# ===================================================================
# متغيرات البيئة — Rahati Store
# انسخي هذا الملف إلى .env وأدخلي القيم الصحيحة
# لا تضيفي .env لـ git (مُضاف لـ .gitignore)
# ===================================================================

# رابط Google Apps Script Webhook (يُضبط من لوحة الإدارة /admin/ عادةً)
# WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# بيئة Cloudflare Workers (اختياري)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
